# Variables d'environnement pour Wedding Share

# Supabase
SUPABASE_URL=https://your-project.supabase.co
# Utiliser la clé service role depuis Supabase Dashboard > Settings > API
# Pas la clé publique anon ni le JWT du client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET_NAME=wedding-media

# Supabase S3 compatible storage (bucket privé)
# Supabase Dashboard > Storage > S3 Access Keys
SUPABASE_S3_ACCESS_KEY=your-s3-access-key
SUPABASE_S3_SECRET_KEY=your-s3-secret-key
SUPABASE_S3_REGION=your-s3-region
# ex: https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3

# Backend
PORT=10000

# Frontend (Render env vars for Vite build)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=https://your-render-app.onrender.com
