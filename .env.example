# Variables d'environnement pour Wedding Share

# Supabase
SUPABASE_URL=https://your-project.supabase.co
# Utiliser la clé service role depuis Supabase Dashboard > Settings > API
# Pas la clé publique anon ni le JWT du client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET_NAME=wedding-media

# Backend
PORT=10000
